---
import fs from 'node:fs';
import path from 'node:path';

const repoRoot = path.resolve(process.cwd(), '..');
const messagesPath = path.join(repoRoot, 'data', 'messages.json');
const metaPath = path.join(repoRoot, 'data', 'meta.json');

const items = JSON.parse(fs.readFileSync(messagesPath, 'utf-8'));
const meta = fs.existsSync(metaPath) ? JSON.parse(fs.readFileSync(metaPath, 'utf-8')) : {};

function formatGroup(dateStr) {
  const d = new Date(dateStr);
  return `${d.getMonth() + 1}月${d.getDate()}日`;
}
function formatTime(dateStr) {
  const d = new Date(dateStr);
  const hh = String(d.getHours()).padStart(2, '0');
  const mm = String(d.getMinutes()).padStart(2, '0');
  return `${hh}:${mm}`;
}
function escAttr(str = '') {
  return str
    .replace(/&/g, '&amp;')
    .replace(/"/g, '&quot;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
}

const grouped = new Map();
for (const item of items) {
  const key = formatGroup(item.datetime || '');
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key).push(item);
}
const groups = Array.from(grouped.entries()).map(([date, list]) => ({ date, list }));
const updated = meta.updated_at || '';
const pageState = JSON.stringify({ updated });
---
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>新闻快讯</title>
    <style>
      :root { --bg:#f5f7fb; --surface:#ffffff; --line:#e6ebf2; --text:#24324a; --muted:#7f8da3; --strong:#17253d; --accent:#e53935; --accent-soft:#fff1f0; --topbar:#ffffff; --chip:#f0f4fa; }
      html.dark { --bg:#0f1722; --surface:#131c28; --line:#223042; --text:#e7edf6; --muted:#8fa0b5; --strong:#f5f8fc; --accent:#ff5b57; --accent-soft:rgba(255,91,87,.14); --topbar:#131c28; --chip:#182332; }
      *{box-sizing:border-box} body{margin:0;background:var(--bg);color:var(--text);font-family:-apple-system,BlinkMacSystemFont,'PingFang SC','Hiragino Sans GB','Microsoft YaHei','Noto Sans CJK SC','Source Han Sans SC',sans-serif}
      .topbar{position:sticky;top:0;z-index:30;background:var(--topbar);border-bottom:1px solid var(--line)}
      .topbar-inner{max-width:1120px;margin:0 auto;padding:12px 18px;display:flex;align-items:center;justify-content:space-between;gap:16px}
      .brand{display:flex;align-items:center;gap:10px;min-width:0}.brand-mark{width:5px;height:18px;border-radius:3px;background:var(--accent)}
      .brand-title{font-size:28px;font-weight:800;letter-spacing:-.01em;color:var(--strong);white-space:nowrap}.tools{display:flex;gap:8px;align-items:center;justify-content:flex-end;flex:1;min-width:0}.search,.btn{border:1px solid var(--line);background:var(--surface);color:var(--text);border-radius:8px;font-size:13px;padding:9px 14px}.search{width:320px;min-width:0;max-width:100%;background:var(--chip)}.btn{cursor:pointer;background:var(--chip)}.icon-btn{width:38px;height:38px;padding:0;display:inline-flex;align-items:center;justify-content:center;font-size:18px;line-height:1}
      .page{max-width:980px;margin:0 auto;padding:16px 14px 40px;width:100%}.notice{display:none;align-items:center;justify-content:space-between;gap:10px;background:var(--accent-soft);color:var(--accent);border:1px solid rgba(229,57,53,.18);border-radius:10px;padding:12px 14px;margin-bottom:14px;font-size:13px}
      
      .date-group{margin-top:18px}.date-title{margin:0 0 10px;font-size:15px;font-weight:700;color:var(--strong);display:flex;align-items:center;gap:8px}.date-title::before{content:'';width:5px;height:5px;border-radius:999px;background:var(--accent)}
      .feed{background:var(--surface);border:1px solid var(--line);border-radius:10px;overflow:hidden}.item{display:grid;grid-template-columns:64px 1fr;gap:0;padding:14px 16px;border-top:1px solid var(--line)}.item:first-child{border-top:none}
      .time{font-size:13px;color:var(--accent);font-weight:700;line-height:1.35;padding-top:2px}.content{min-width:0}.text{color:var(--strong);font-size:17px;line-height:1.6;font-weight:500;word-break:break-word;white-space:pre-wrap}
      .toggle{margin-top:8px;border:none;background:transparent;color:var(--muted);cursor:pointer;padding:0;font-size:12px}
      @media (max-width:900px){.page{max-width:760px}.topbar-inner{max-width:760px;padding:12px 14px}.search{width:220px}} @media (max-width:640px){.topbar-inner{padding:10px 10px;gap:10px;flex-wrap:wrap;justify-content:center}.brand{width:100%;justify-content:center}.brand-title{font-size:24px}.tools{width:100%;justify-content:center;flex-wrap:nowrap}.search{flex:1;width:auto;min-width:0;max-width:none}.btn{padding:8px 10px;font-size:12px}.icon-btn{width:34px;height:34px;font-size:16px}.page{padding:10px 10px 24px}.item{grid-template-columns:56px 1fr;padding:12px 12px}.time{font-size:12px}.text{font-size:15px;line-height:1.56}.date-title{font-size:14px}}
    </style>
  </head>
  <body>
    <script id="page-state" type="application/json" set:html={pageState}></script>
    <header class="topbar"><div class="topbar-inner"><div class="brand"><span class="brand-mark"></span><div class="brand-title">新闻快讯</div></div><div class="tools"><input id="searchInput" class="search" placeholder="搜索快讯关键词" /><button id="refreshBtn" class="btn">刷新</button><button id="themeBtn" class="btn icon-btn" aria-label="切换主题" title="切换主题">◐</button></div></div></header>
    <main class="page"><div id="updateNotice" class="notice"><span>检测到新内容，点击刷新查看最新快讯。</span><button class="btn" id="noticeRefreshBtn">立即刷新</button></div>
      {groups.map(group => (<section class="date-group"><h2 class="date-title">{group.date}</h2><div class="feed">{group.list.map(item => {const fullText = item.text || ''; const shortText = fullText.length <= 180 ? fullText : fullText.slice(0, 180).trimEnd() + '...'; const needToggle = fullText.length > 180; return (<article class="item" data-search={fullText.toLowerCase()}><div class="time">{formatTime(item.datetime || '')}</div><div class="content"><div class="text" data-full={fullText} data-short={shortText}>{shortText}</div>{needToggle && <button class="toggle">展开全文</button>}</div></article>);})}</div></section>))}
    </main>
    <script>
      (() => {
        const state = JSON.parse(document.getElementById('page-state')?.textContent || '{}');
        const initialUpdatedAt = state.updated || '';
        const html = document.documentElement;
        const savedTheme = localStorage.getItem('cjmb-theme');
        if (savedTheme === 'dark') html.classList.add('dark');
        const searchInput = document.getElementById('searchInput');
        const refreshBtn = document.getElementById('refreshBtn');
        const themeBtn = document.getElementById('themeBtn');
        const notice = document.getElementById('updateNotice');
        const noticeRefreshBtn = document.getElementById('noticeRefreshBtn');
        function applyThemeToggle(){ html.classList.toggle('dark'); localStorage.setItem('cjmb-theme', html.classList.contains('dark') ? 'dark' : 'light'); }
        function refreshPage(){ window.location.reload(); }
        function filterCards(){ const q = (searchInput.value || '').toLowerCase().trim(); document.querySelectorAll('.item').forEach(item => { const hay = item.dataset.search || ''; item.style.display = !q || hay.includes(q) ? '' : 'none'; }); }
        function toggleItem(btn){ const text = btn.parentElement.querySelector('.text'); const expanded = btn.dataset.expanded === '1'; if (expanded) { text.textContent = text.dataset.short || ''; btn.dataset.expanded = '0'; btn.textContent = '展开全文'; } else { text.textContent = text.dataset.full || ''; btn.dataset.expanded = '1'; btn.textContent = '收起'; } }
        async function checkForUpdates(){ try { const res = await fetch('./meta.json?ts=' + Date.now(), { cache: 'no-store' }); if (!res.ok) return; const meta = await res.json(); if (meta.updated_at && meta.updated_at !== initialUpdatedAt) notice.style.display = 'flex'; } catch {} }
        searchInput?.addEventListener('input', filterCards); refreshBtn?.addEventListener('click', refreshPage); themeBtn?.addEventListener('click', applyThemeToggle); noticeRefreshBtn?.addEventListener('click', refreshPage); document.querySelectorAll('.toggle').forEach(btn => btn.addEventListener('click', () => toggleItem(btn))); setInterval(checkForUpdates, 60000);
      })();
    </script>
  </body>
</html>
