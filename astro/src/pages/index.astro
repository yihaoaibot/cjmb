---
import fs from 'node:fs';
import path from 'node:path';

const repoRoot = path.resolve(process.cwd(), '..');
const messagesPath = path.join(repoRoot, 'data', 'messages.json');
const metaPath = path.join(repoRoot, 'data', 'meta.json');

const items = JSON.parse(fs.readFileSync(messagesPath, 'utf-8'));
const meta = fs.existsSync(metaPath) ? JSON.parse(fs.readFileSync(metaPath, 'utf-8')) : {};

function formatGroup(dateStr) {
  const d = new Date(dateStr);
  return `${d.getMonth() + 1}月${d.getDate()}日`;
}
function formatTime(dateStr) {
  const d = new Date(dateStr);
  const hh = String(d.getHours()).padStart(2, '0');
  const mm = String(d.getMinutes()).padStart(2, '0');
  return `${hh}:${mm}`;
}

const grouped = new Map();
for (const item of items) {
  const key = formatGroup(item.datetime || '');
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key).push(item);
}
const groups = Array.from(grouped.entries()).map(([date, list]) => ({ date, list }));
const updated = meta.updated_at || '';
const count = items.length;
---
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>财经慢报 Feed</title>
    <style>
      :root {
        --bg: #f7f8fa;
        --surface: #ffffff;
        --line: #e5e7eb;
        --text: #111827;
        --muted: #6b7280;
        --accent: #d92d20;
        --accent-soft: #fff1f0;
        --topbar: rgba(255,255,255,.92);
      }
      html.dark {
        --bg: #0f141b;
        --surface: #161c24;
        --line: #26303c;
        --text: #e5e7eb;
        --muted: #98a2b3;
        --accent: #ff6b5f;
        --accent-soft: rgba(255,107,95,.12);
        --topbar: rgba(15,20,27,.9);
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      }
      .page { max-width: 980px; margin: 0 auto; padding: 0 16px 48px; }
      .topbar {
        position: sticky; top: 0; z-index: 20;
        background: var(--topbar);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--line);
        margin: 0 -16px 18px;
        padding: 14px 16px;
      }
      .topbar-inner {
        max-width: 980px; margin: 0 auto; display:flex; gap:12px; align-items:center; justify-content:space-between; flex-wrap:wrap;
      }
      .brand { display:flex; flex-direction:column; gap:4px; }
      .brand h1 { margin:0; font-size:26px; letter-spacing:-.02em; }
      .brand .meta { font-size:13px; color: var(--muted); }
      .top-actions { display:flex; gap:10px; align-items:center; flex-wrap:wrap; }
      .btn, .search {
        border:1px solid var(--line); background: var(--surface); color: var(--text);
        border-radius: 10px; padding: 10px 12px; font-size: 14px;
      }
      .btn { cursor: pointer; }
      .search { min-width: 220px; }
      .notice {
        display:none; margin: 10px 0 18px; padding: 12px 14px; border-radius: 12px;
        background: var(--accent-soft); color: var(--accent); border: 1px solid rgba(217,45,32,.15);
        justify-content: space-between; align-items:center; gap:12px;
      }
      .summary { display:flex; gap:10px; flex-wrap:wrap; margin-bottom: 20px; }
      .pill {
        background: var(--surface); border:1px solid var(--line); color: var(--muted);
        border-radius: 999px; padding: 7px 11px; font-size: 12px;
      }
      .date-group { margin: 26px 0 8px; }
      .date-title {
        margin: 0 0 10px; font-size: 18px; font-weight: 700; display:flex; align-items:center; gap:10px;
      }
      .date-title::before {
        content: ''; width: 10px; height: 10px; border-radius: 999px; background: var(--accent);
      }
      .feed {
        background: var(--surface); border:1px solid var(--line); border-radius: 16px; overflow: hidden;
      }
      .item {
        display:grid; grid-template-columns: 68px 1fr; gap: 0; padding: 16px 18px; border-top:1px solid var(--line);
      }
      .item:first-child { border-top: none; }
      .time {
        color: var(--accent); font-weight: 700; font-size: 13px; padding-top: 2px;
      }
      .content {
        min-width: 0;
      }
      .text {
        font-size: 15px; line-height: 1.75; color: var(--text); word-break: break-word;
      }
      .toggle {
        margin-top: 10px; border: none; background: transparent; color: var(--accent); cursor: pointer; padding: 0; font-size: 13px;
      }
      .empty { color: var(--muted); padding: 26px 0; }
      @media (max-width: 640px) {
        .item { grid-template-columns: 1fr; gap: 8px; }
        .topbar-inner { align-items:flex-start; }
        .search { width: 100%; }
      }
    </style>
  </head>
  <body>
    <div class="topbar">
      <div class="topbar-inner">
        <div class="brand">
          <h1>财经慢报</h1>
          <div class="meta">最近更新：<span id="updatedAt">{updated}</span></div>
        </div>
        <div class="top-actions">
          <input id="searchInput" class="search" placeholder="搜索关键词" />
          <button id="refreshBtn" class="btn">刷新</button>
          <button id="themeBtn" class="btn">主题</button>
        </div>
      </div>
    </div>

    <div class="page">
      <div id="updateNotice" class="notice">
        <span>检测到新内容，点击刷新即可查看最新消息。</span>
        <button class="btn" id="noticeRefreshBtn">立即刷新</button>
      </div>

      <div class="summary">
        <span class="pill">最近 1 天 {count} 条</span>
        <span class="pill">5 分钟自动同步</span>
        <span class="pill">深浅主题</span>
      </div>

      {groups.map(group => (
        <section class="date-group">
          <h2 class="date-title">{group.date}</h2>
          <div class="feed">
            {group.list.map(item => {
              const fullText = item.text || '';
              const shortText = fullText.length <= 180 ? fullText : fullText.slice(0, 180).trimEnd() + '...';
              const needToggle = fullText.length > 180;
              return (
                <article class="item" data-search={(fullText || '').toLowerCase()}>
                  <div class="time">{formatTime(item.datetime || '')}</div>
                  <div class="content">
                    <div class="text" data-full={fullText} data-short={shortText}>{shortText}</div>
                    {needToggle && <button class="toggle">展开</button>}
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      ))}
    </div>

    <script is:inline>
      (() => {
        const initialUpdatedAt = {JSON.stringify(updated)};
        const html = document.documentElement;
        const savedTheme = localStorage.getItem('cjmb-theme');
        if (savedTheme === 'dark') html.classList.add('dark');

        const searchInput = document.getElementById('searchInput');
        const refreshBtn = document.getElementById('refreshBtn');
        const themeBtn = document.getElementById('themeBtn');
        const notice = document.getElementById('updateNotice');
        const noticeRefreshBtn = document.getElementById('noticeRefreshBtn');

        function applyThemeToggle() {
          html.classList.toggle('dark');
          localStorage.setItem('cjmb-theme', html.classList.contains('dark') ? 'dark' : 'light');
        }

        function refreshPage() {
          window.location.reload();
        }

        function filterCards() {
          const q = (searchInput.value || '').toLowerCase().trim();
          document.querySelectorAll('.item').forEach(item => {
            const hay = item.dataset.search || '';
            item.style.display = !q || hay.includes(q) ? '' : 'none';
          });
        }

        function toggleItem(btn) {
          const text = btn.parentElement.querySelector('.text');
          const expanded = btn.dataset.expanded === '1';
          if (expanded) {
            text.textContent = text.dataset.short || '';
            btn.dataset.expanded = '0';
            btn.textContent = '展开';
          } else {
            text.textContent = text.dataset.full || '';
            btn.dataset.expanded = '1';
            btn.textContent = '收起';
          }
        }

        async function checkForUpdates() {
          try {
            const res = await fetch('./data/meta.json?ts=' + Date.now(), { cache: 'no-store' });
            if (!res.ok) return;
            const meta = await res.json();
            if (meta.updated_at && meta.updated_at !== initialUpdatedAt) {
              notice.style.display = 'flex';
            }
          } catch (e) {}
        }

        searchInput?.addEventListener('input', filterCards);
        refreshBtn?.addEventListener('click', refreshPage);
        themeBtn?.addEventListener('click', applyThemeToggle);
        noticeRefreshBtn?.addEventListener('click', refreshPage);
        document.querySelectorAll('.toggle').forEach(btn => btn.addEventListener('click', () => toggleItem(btn)));
        setInterval(checkForUpdates, 60000);
      })();
    </script>
  </body>
</html>
