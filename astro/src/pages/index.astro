---
import fs from 'node:fs';
import path from 'node:path';

const repoRoot = path.resolve(process.cwd(), '..');
const messagesPath = path.join(repoRoot, 'data', 'messages.json');
const metaPath = path.join(repoRoot, 'data', 'meta.json');
const clsvipPath = path.join(repoRoot, 'data', 'clsvip_messages.json');
const clsvipMetaPath = path.join(repoRoot, 'data', 'clsvip_meta.json');

const items = JSON.parse(fs.readFileSync(messagesPath, 'utf-8'));
const meta = fs.existsSync(metaPath) ? JSON.parse(fs.readFileSync(metaPath, 'utf-8')) : {};
const clsvipItems = fs.existsSync(clsvipPath) ? JSON.parse(fs.readFileSync(clsvipPath, 'utf-8')) : [];
const clsvipMeta = fs.existsSync(clsvipMetaPath) ? JSON.parse(fs.readFileSync(clsvipMetaPath, 'utf-8')) : {};

const zhDate = new Intl.DateTimeFormat('zh-CN', { timeZone: 'Asia/Shanghai', month: 'numeric', day: 'numeric' });
const zhTime = new Intl.DateTimeFormat('zh-CN', { timeZone: 'Asia/Shanghai', hour: '2-digit', minute: '2-digit', hour12: false });

function formatGroup(dateStr) {
  const parts = zhDate.formatToParts(new Date(dateStr));
  const month = parts.find(p => p.type === 'month')?.value || '';
  const day = parts.find(p => p.type === 'day')?.value || '';
  return `${month}月${day}日`;
}
function formatTime(dateStr) {
  return zhTime.format(new Date(dateStr));
}

const grouped = new Map();
for (const item of items) {
  const key = formatGroup(item.datetime || '');
  if (!grouped.has(key)) grouped.set(key, []);
  grouped.get(key).push(item);
}
const groups = Array.from(grouped.entries()).map(([date, list]) => ({ date, list }));
const clsvipGrouped = new Map();
for (const item of clsvipItems) {
  const key = formatGroup(item.datetime || '');
  if (!clsvipGrouped.has(key)) clsvipGrouped.set(key, []);
  clsvipGrouped.get(key).push(item);
}
const clsvipGroups = Array.from(clsvipGrouped.entries()).map(([date, list]) => ({ date, list: list.slice(0, 8) }));
const updated = meta.updated_at || '';
const pageState = JSON.stringify({ updated, clsvipUpdated: clsvipMeta.updated_at || '' });
---
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>财经慢报 · 最新快讯流</title>
    <style is:global>
      :root { --bg:#f5f6f7; --surface:#ffffff; --line:#ececec; --text:#222; --muted:#8a8f99; --strong:#111; --accent:#f85959; --accent-soft:#fff2f2; --topbar:rgba(255,255,255,.98); }
      html.dark { --bg:#131416; --surface:#1a1b1f; --line:#2a2d33; --text:#ececec; --muted:#9aa0a6; --strong:#fff; --accent:#ff6b6b; --accent-soft:rgba(248,89,89,.14); --topbar:rgba(19,20,22,.96); }
      *{box-sizing:border-box}
      body{margin:0;background:var(--bg);color:var(--text);font-family:-apple-system,BlinkMacSystemFont,'PingFang SC','Hiragino Sans GB','Microsoft YaHei','Noto Sans CJK SC','Source Han Sans SC',sans-serif}
      .topbar{position:sticky;top:0;z-index:30;background:var(--topbar);border-bottom:1px solid var(--line);backdrop-filter:blur(10px)}
      .topbar-inner{max-width:820px;margin:0 auto;padding:10px 14px;display:flex;align-items:center;justify-content:space-between;gap:10px}
      .brand{display:flex;align-items:center;gap:12px}
      .brand-mark{width:8px;height:20px;border-radius:999px;background:var(--accent)}
      .brand-title{font-size:24px;font-weight:800;letter-spacing:-.01em;color:var(--strong)}
      .tools{display:flex;gap:8px;align-items:center;min-width:0;flex:1;justify-content:flex-end}
      .search,.btn,.topic-btn{border:1px solid var(--line);background:var(--surface);color:var(--text);border-radius:999px;font-size:13px;padding:8px 12px}
      .search{min-width:0;width:240px;max-width:100%}
      .btn,.topic-btn{cursor:pointer}
      .topic-btn.is-active{background:var(--accent-soft);color:var(--accent);border-color:rgba(248,89,89,.22);font-weight:700}
      .icon-btn{width:34px;height:34px;padding:0;display:inline-flex;align-items:center;justify-content:center;font-size:16px;line-height:1}
      .page{max-width:820px;margin:0 auto;padding:12px 12px 24px}
      .notice{display:none;align-items:center;justify-content:space-between;gap:10px;background:var(--accent-soft);color:var(--accent);border:1px solid rgba(248,89,89,.18);border-radius:12px;padding:12px 14px;margin-bottom:14px;font-size:13px}
      .date-group{margin-top:14px}
      .date-title{margin:0 0 8px;font-size:14px;font-weight:700;color:var(--strong);display:flex;align-items:center;gap:8px}
      .date-title::before{content:'';width:6px;height:6px;border-radius:999px;background:var(--accent)}
      .feed{background:var(--surface);border:1px solid var(--line);border-radius:10px;overflow:hidden}
      .item{display:grid;grid-template-columns:56px 1fr;gap:0;padding:12px 12px 11px;border-top:1px solid var(--line)}
      .item:first-child{border-top:none}
      .time{font-size:12px;color:var(--accent);font-weight:700;line-height:1.4;padding-top:2px}
      .content{min-width:0}
      .text{color:var(--strong);font-size:16px;line-height:1.58;font-weight:500;word-break:break-word;white-space:pre-wrap}
      .toggle{margin-top:6px;border:none;background:transparent;color:var(--muted);cursor:pointer;padding:0;font-size:12px}
      @media (max-width:640px){
        .topbar-inner{padding:10px 10px;gap:8px;flex-wrap:wrap}
        .brand{width:100%;justify-content:center}
        .brand-title{font-size:22px}
        .tools{width:100%;justify-content:center;flex-wrap:nowrap}
        .search{flex:1;width:auto;min-width:0;max-width:none}
        .btn{padding:7px 10px;font-size:12px}
        .icon-btn{width:32px;height:32px;font-size:15px}
        .page{padding:10px 8px 20px}
        .date-group{margin-top:12px}
        .date-title{font-size:13px;margin-bottom:6px}
        .feed{border-radius:8px}
        .item{grid-template-columns:48px 1fr;gap:0;padding:10px 10px 9px}
        .time{font-size:12px;padding-top:1px}
        .text{font-size:15px;line-height:1.52}
      }
    </style>
  </head>
  <body>
    <script id="page-state" type="application/json" set:html={pageState}></script>
    <header class="topbar"><div class="topbar-inner"><div class="brand"><span class="brand-mark"></span><div class="brand-title">财经慢报</div></div><div class="tools"><input id="searchInput" class="search" placeholder="搜索最新快讯关键词" /><button id="refreshBtn" class="btn">刷新</button><button id="themeBtn" class="btn icon-btn" aria-label="切换主题" title="切换主题">◐</button></div></div></header>
    <main class="page"><div id="updateNotice" class="notice"><span>检测到新内容，点击刷新查看最新快讯流。</span><button class="btn" id="noticeRefreshBtn">立即刷新</button></div><div style="margin:8px 0 0;font-size:12px;color:var(--muted);">当前页面以最新快讯流为主，附带独立的 clsvip 频道信息模块。</div><div id="topicSwitch" style="display:flex;gap:8px;flex-wrap:wrap;margin:10px 0 2px;"><button class="topic-btn" type="button" id="topic-main" data-topic="main">快讯</button><button class="topic-btn" type="button" id="topic-clsvip" data-topic="vip">VIP</button></div>
      <div id="mainTopic">{groups.map(group => (<section class="date-group"><h2 class="date-title">{group.date}</h2><div class="feed">{group.list.map(item => {const fullText = item.text || ''; const shortText = fullText.length <= 180 ? fullText : fullText.slice(0, 180).trimEnd() + '...'; const needToggle = fullText.length > 180; return (<article class="item" data-search={fullText.toLowerCase()}><div class="time">{formatTime(item.datetime || '')}</div><div class="content"><div class="text" data-full={fullText} data-short={shortText}>{shortText}</div>{needToggle && <button class="toggle">展开全文</button>}</div></article>);})}</div></section>))}</div>
      <div id="vipTopic" style="display:none;">
      {clsvipGroups.map(group => (
        <section class="date-group">
          <h2 class="date-title">{group.date} · VIP</h2>
          <div class="feed">
            {group.list.map(item => {
              const fullText = item.text || '';
              const text = fullText ? (fullText.length <= 160 ? fullText : fullText.slice(0, 160).trimEnd() + '...') : '图片 / 媒体内容，点击查看原帖';
              return (
                <article class="item" data-search={(fullText || 'clsvip media').toLowerCase()}>
                  <div class="time">{formatTime(item.datetime || '')}</div>
                  <div class="content">
                    <div class="text">{text}</div>
                    <div style="margin-top:8px;font-size:12px;color:var(--muted);display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
                      <span>{item.media_only ? '媒体帖' : '文本帖'}</span>
                      <a href={item.url} target="_blank" rel="noreferrer" style="color:var(--accent);text-decoration:none;font-weight:700;">查看原帖</a>
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      ))}
    </div></section>
    </main>
    <script is:inline>
      (() => {
        const mainBtn = document.getElementById('topic-main');
        const vipBtn = document.getElementById('topic-clsvip');
        const mainTopic = document.getElementById('mainTopic');
        const vipTopic = document.getElementById('vipTopic');
        function filterCards(){ const q = (searchInput?.value || '').toLowerCase().trim(); const scope = (localStorage.getItem('cjmb-topic') || 'main') === 'vip' ? vipTopic : mainTopic; scope?.querySelectorAll('.item').forEach(item => { const hay = item.dataset.search || ''; item.style.display = !q || hay.includes(q) ? '' : 'none'; }); }
        function setTopic(topic){
          const isVip = topic === 'vip';
          if (mainTopic) mainTopic.style.display = isVip ? 'none' : 'block';
          if (vipTopic) vipTopic.style.display = isVip ? 'block' : 'none';
          mainBtn?.classList.toggle('is-active', !isVip);
          vipBtn?.classList.toggle('is-active', isVip);
          localStorage.setItem('cjmb-topic', topic);
          filterCards();
        }
        searchInput?.addEventListener('input', filterCards);
        mainBtn?.addEventListener('click', () => setTopic('main'));
        vipBtn?.addEventListener('click', () => setTopic('vip'));
        setTopic(localStorage.getItem('cjmb-topic') || 'main');
      })();
    </script>
    <script is:inline src="/cjmb/feed-client.js"></script>
  </body>
</html>
